{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CommandBlock",
  "version": "2.3.0",
  "identifier": "app.commandblock.desktop",
  "build": {
    "beforeBuildCommand": "node scripts/publish-sidecar.mjs",
    "frontendDist": "loading"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/PianoNic/CommandBlock/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_OUTPUT_OF__npx_tauri_signer_generate"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CommandBlock",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg", "deb", "rpm", "appimage"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/commandblock-api"],
    "resources": ["resources/commandblock.yaml", "resources/wwwroot/**/*"]
  }
}
