{
  "interactiveLogin": false,
  "tokenCallbacks": [
    {
      "issuerId": "default",
      "tokenExpiry": 3600,
      "requestMappings": [
        {
          "requestParam": "client_id",
          "match": "commandblock",
          "claims": {
            "sub": "commandblock-admin",
            "name": "Demo Admin",
            "given_name": "Demo",
            "family_name": "Admin",
            "preferred_username": "admin",
            "email": "admin@commandblock.local",
            "email_verified": true,
            "roles": ["admin"]
          }
        }
      ]
    }
  ]
}
